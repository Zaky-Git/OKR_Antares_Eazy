              "mode": "raw",
              "raw": "{\n  \"name\": \"Zaky\",\n  \"email\": \"zaky@antares.id\",\n  \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "register"]
